---
import Layout from '../components/Layout.astro';
---

<Layout title="Set New Password - Der Town">
  <div class="container mx-auto max-w-md py-20 px-4">
    <div class="rounded-lg border border-gray-300 p-8">
      <h1 class="mb-2 text-2xl font-bold">Set new password</h1>

      <!-- Loading state while Supabase processes the token -->
      <div id="loading" class="py-4 text-gray-500 text-sm">Verifying your link…</div>

      <!-- Error state (invalid / expired link) -->
      <div id="link-error" class="hidden">
        <div class="mb-4 rounded-md bg-red-50 p-3 text-red-700">
          This link has expired or is invalid. Please
          <a href="/forgot-password" class="underline font-medium">request a new one</a>.
        </div>
      </div>

      <!-- Password form (shown once token is valid) -->
      <form id="update-form" class="hidden space-y-4">
        <p class="text-gray-600 text-sm mb-4">Choose a new password for your account.</p>

        <div>
          <label for="new-password" class="block text-sm font-medium text-gray-700">New password</label>
          <input
            type="password"
            id="new-password"
            required
            minlength="8"
            class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-blue-500 focus:outline-none"
            placeholder="At least 8 characters"
          />
        </div>

        <div>
          <label for="confirm-password" class="block text-sm font-medium text-gray-700">Confirm password</label>
          <input
            type="password"
            id="confirm-password"
            required
            minlength="8"
            class="mt-1 w-full rounded-md border border-gray-300 px-3 py-2 focus:border-blue-500 focus:outline-none"
            placeholder="Re-enter your password"
          />
        </div>

        <div id="form-error" class="hidden rounded-md bg-red-50 p-3 text-red-700 text-sm"></div>

        <button
          type="submit"
          id="submit-btn"
          class="w-full rounded-md bg-indigo-600 py-2 text-white font-medium hover:bg-indigo-700"
        >
          Set password
        </button>
      </form>

      <!-- Success state -->
      <div id="success" class="hidden">
        <div class="rounded-md bg-green-50 p-3 text-green-700">
          Password updated! Taking you to the admin panel…
        </div>
      </div>
    </div>
  </div>
</Layout>

<script>
  import { createClient } from '@supabase/supabase-js';

  // PUBLIC_ vars are safe to expose and available in bundled client scripts
  const supabase = createClient(
    import.meta.env.PUBLIC_SUPABASE_URL,
    import.meta.env.PUBLIC_SUPABASE_KEY
  );

  const loadingEl  = document.getElementById('loading')!;
  const linkError  = document.getElementById('link-error')!;
  const updateForm = document.getElementById('update-form')!;
  const formError  = document.getElementById('form-error')!;
  const successEl  = document.getElementById('success')!;

  function show(el: HTMLElement) { el.classList.remove('hidden'); }
  function hide(el: HTMLElement) { el.classList.add('hidden'); }

  // Supabase fires PASSWORD_RECOVERY when it detects the recovery token in the URL hash.
  // It may also fire SIGNED_IN (existing session) before PASSWORD_RECOVERY arrives, so we
  // ONLY act on PASSWORD_RECOVERY here — other events are ignored. The fallback timer
  // handles the "link expired / never fired" case so we never show both states at once.
  const { data: { subscription } } = supabase.auth.onAuthStateChange((event) => {
    if (event === 'PASSWORD_RECOVERY') {
      clearTimeout(fallbackTimer);
      hide(loadingEl);
      show(updateForm);
    }
    // All other events (SIGNED_IN, SIGNED_OUT, etc.) are intentionally ignored here.
  });

  // If PASSWORD_RECOVERY hasn't fired within 4 seconds the link is bad/expired
  const fallbackTimer = setTimeout(() => {
    if (!loadingEl.classList.contains('hidden')) {
      hide(loadingEl);
      show(linkError);
    }
  }, 4000);

  updateForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    clearTimeout(fallbackTimer);
    hide(formError);

    const password = (document.getElementById('new-password') as HTMLInputElement).value;
    const confirm  = (document.getElementById('confirm-password') as HTMLInputElement).value;
    const btn      = document.getElementById('submit-btn') as HTMLButtonElement;

    if (password !== confirm) {
      formError.textContent = 'Passwords do not match.';
      show(formError);
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Saving…';

    const { error } = await supabase.auth.updateUser({ password });

    if (error) {
      formError.textContent = error.message;
      show(formError);
      btn.disabled = false;
      btn.textContent = 'Set password';
      return;
    }

    subscription.unsubscribe();
    hide(updateForm);
    show(successEl);
    setTimeout(() => { window.location.href = '/admin'; }, 2000);
  });
</script>
