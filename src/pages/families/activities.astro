---
import Layout from '../../components/Layout.astro';
import SectionHeader from '../../components/ui/SectionHeader.astro';
import LinkBox from '../../components/ui/LinkBox.astro';
import Disclaimer from '../../components/ui/Disclaimer.astro';
import { supabase } from '../../lib/supabase';

// Lightweight counts for the hub cards. Best-effort — if the query fails
// (e.g. migration not yet applied), the cards still render without counts.
let campCount: number | null = null;
let programCount: number | null = null;
try {
  const { count: camps } = await (supabase as any)
    .from('public_activities')
    .select('id', { count: 'exact', head: true })
    .eq('activity_hierarchy_type', 'PROGRAM')
    .eq('status', 'approved')
    .eq('program_format', 'camp');
  campCount = camps ?? null;

  const { count: programs } = await (supabase as any)
    .from('public_activities')
    .select('id', { count: 'exact', head: true })
    .eq('activity_hierarchy_type', 'PROGRAM')
    .eq('status', 'approved')
    .or('program_format.neq.camp,program_format.is.null');
  programCount = programs ?? null;
} catch {
  // Counts are optional; ignore failures.
}

const campSubtext = campCount != null ? `${campCount} camp${campCount === 1 ? '' : 's'} listed` : undefined;
const programSubtext =
  programCount != null ? `${programCount} program${programCount === 1 ? '' : 's'} listed` : undefined;
---

<Layout
  title="Activities - Families | Der Town"
  description="Find camps, programs, classes, leagues, and after-school activities for children of all ages in the Leavenworth area."
>
  <div class="bg-white min-h-screen">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <SectionHeader
        title="Activities for Kids"
        icon="sports_and_outdoors"
        text="Camps, programs, classes, leagues, and after-school activities for children of all ages in the Leavenworth area. Pick a category to start browsing."
      />

      <div class="bg-white rounded-lg shadow-lg p-6 mt-6">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <LinkBox
            title="Camps"
            text="Summer and school-break camps — browse by week to find something for a specific date, like the week of July 14."
            subtext={campSubtext}
            link="/families/camps"
            icon="cabin"
            external={false}
          />
          <LinkBox
            title="Programs, Classes & Leagues"
            text="Recurring programs, classes, lessons, and sports leagues that run through the school year and beyond."
            subtext={programSubtext}
            link="/families/programs"
            icon="emoji_events"
            external={false}
          />
          <LinkBox
            title="After-School Activities"
            text="Curated after-school programs and clubs organized by school and grade level."
            link="/families/after-school-activities"
            icon="backpack"
            external={false}
          />
          <LinkBox
            title="School"
            text="School calendars, enrollment, and district information for local families."
            link="/families/school"
            icon="school"
            external={false}
          />
        </div>
      </div>

      <div class="mt-8">
        <Disclaimer
          text="Activity details are provided by organizers and may change. Always confirm dates, ages, and registration directly with the program before signing up."
        />
      </div>
    </div>
  </div>
</Layout>
