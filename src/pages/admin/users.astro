---
import AdminLayout from '../../components/AdminLayout.astro';
import { getSessionFromCookies } from '../../lib/session';
import { checkAdminAccess } from '../../lib/session';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const { session } = await getSessionFromCookies({ cookieHeader });
if (!session) {
  const redirectTo = Astro.url.pathname + Astro.url.search;
  return Astro.redirect(`/login?redirect=${encodeURIComponent(redirectTo)}`);
}

const { role } = await checkAdminAccess({ cookieHeader });
if (role !== 'super_admin') {
  return Astro.redirect('/admin');
}

const userEmail = session.user?.email || 'Admin';
const siteOrigin = Astro.url.origin;
---

<AdminLayout title="User Permissions" userEmail={userEmail}>
  <Fragment slot="actions">
    <button
      type="button"
      onclick="openAddUserModal()"
      class="icon-btn btn-save"
      aria-label="Add user"
    >
      <span class="material-symbols-outlined text-2xl">person_add</span>
      <span class="tooltip">Add user</span>
    </button>
  </Fragment>

  <div class="page-intro">
    <p>
      Manage who can access the admin panel. <strong>Super admins</strong> have full access.
      <strong>Org editors</strong> can view and edit events &amp; announcements only for their
      assigned organizations.
    </p>
  </div>

  <div id="page-banner" class="page-banner" style="display:none"></div>
  <div id="users-loading" class="loading">Loading users…</div>
  <div id="users-container"></div>

  <!-- Email allowlist section -->
  <hr class="my-10 border-t border-gray-200" />

  <div class="flex justify-between items-start mb-4">
    <div>
      <h2 class="text-base font-bold text-gray-900 m-0">Signup allowlist</h2>
      <p class="text-sm text-gray-500 mt-1 mb-0">Only these email addresses can create accounts via the registration page. Adding a user above automatically adds them here too.</p>
    </div>
  </div>

  <div class="flex gap-2 mb-4 max-w-md">
    <input
      type="email"
      id="allowlist-email-input"
      class="field-input flex-1"
      placeholder="email@example.com"
    />
    <button type="button" onclick="addToAllowlist()" class="btn-add-org">Add email</button>
  </div>

  <div id="allowlist-loading" class="loading">Loading allowlist…</div>
  <div id="allowlist-container"></div>
</AdminLayout>

<!-- ── Add / Edit User Modal ──────────────────────────────────────────────── -->
<dialog id="user-modal" class="modal-dialog">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modal-title" class="modal-title">Add user</h2>
      <button type="button" onclick="closeUserModal()" class="modal-close" aria-label="Close">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <form id="user-form" onsubmit="handleUserFormSubmit(event)">
      <input type="hidden" id="form-user-id" value="" />

      <!-- Email (shown only when adding a new user) -->
      <div class="field" id="email-field">
        <label for="form-email" class="field-label">Email address</label>
        <input
          type="email"
          id="form-email"
          name="email"
          class="field-input"
          placeholder="user@example.com"
        />
        <p class="field-hint">
          No email is sent yet. Use the "Send invite" button after saving to notify them.
        </p>
      </div>

      <!-- Role -->
      <div class="field">
        <label class="field-label">Role</label>
        <div class="role-options">
          <label class="role-option">
            <input type="radio" name="role" value="org_editor" id="role-org-editor" checked />
            <span class="role-label">
              <strong>Org editor</strong>
              <span class="role-desc">Can edit events &amp; announcements for their assigned organizations</span>
            </span>
          </label>
          <label class="role-option">
            <input type="radio" name="role" value="super_admin" id="role-super-admin" />
            <span class="role-label">
              <strong>Super admin</strong>
              <span class="role-desc">Full access — approve, publish, manage all orgs and users</span>
            </span>
          </label>
        </div>
      </div>

      <!-- Org assignments (shown when editing an org_editor) -->
      <div class="field" id="orgs-field" style="display:none">
        <label class="field-label">Organization access</label>
        <div id="orgs-list" class="orgs-list"></div>
        <div class="add-org-row">
          <select id="org-select" class="field-input field-select">
            <option value="">— Add an organization —</option>
          </select>
          <button type="button" onclick="addOrgToUser()" class="btn-add-org">Add</button>
        </div>
      </div>

      <div id="form-error" class="form-error" style="display:none"></div>

      <div class="modal-footer">
        <button type="button" onclick="closeUserModal()" class="btn-cancel">Cancel</button>
        <button type="submit" id="form-submit" class="btn-primary">Save</button>
      </div>
    </form>
  </div>
</dialog>

<!-- ── Send Invite Modal ───────────────────────────────────────────────────── -->
<dialog id="invite-modal" class="modal-dialog">
  <div class="modal-content">
    <div class="modal-header">
      <h2 class="modal-title">Send invite</h2>
      <button type="button" onclick="document.getElementById('invite-modal').close()" class="modal-close" aria-label="Close">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <div id="invite-preview" class="invite-preview"></div>

    <div id="invite-error" class="form-error" style="display:none"></div>

    <div class="modal-footer">
      <button type="button" onclick="document.getElementById('invite-modal').close()" class="btn-cancel">Cancel</button>
      <button type="button" id="invite-send-btn" onclick="sendInviteConfirmed()" class="btn-primary">
        <span class="material-symbols-outlined" style="font-size:1rem;vertical-align:middle">send</span>
        Send invite email
      </button>
    </div>
  </div>
</dialog>

<script define:vars={{ siteOrigin }}>
  const PRIMARY_ADMIN_EMAIL = 'dertownleavenworth@gmail.com';

  let users = [];
  let allOrgs = [];       // all organizations for the dropdown
  let editingUserId = null;
  let editingUserOrgs = []; // orgs currently assigned to the user being edited

  // ── Bootstrap ─────────────────────────────────────────────────────────────

  // Wire role radio buttons to show/hide org section
  document.querySelectorAll('input[name="role"]').forEach((el) => {
    el.addEventListener('change', syncOrgsFieldVisibility);
  });

  function syncOrgsFieldVisibility() {
    const role = document.querySelector('input[name="role"]:checked')?.value;
    const orgsField = document.getElementById('orgs-field');
    orgsField.style.display = (role === 'org_editor' && editingUserId) ? '' : 'none';
  }

  // ── Load data ─────────────────────────────────────────────────────────────

  async function loadUsers() {
    const loading = document.getElementById('users-loading');
    const container = document.getElementById('users-container');
    try {
      const res = await fetch('/api/admin/users', { credentials: 'include' });
      if (!res.ok) throw new Error('Failed to load users');
      users = await res.json();
      renderUsers();
    } catch (err) {
      container.innerHTML = `<p class="error-text">${err.message}</p>`;
    } finally {
      loading.classList.add('hidden');
    }
  }

  async function loadOrgs() {
    try {
      const res = await fetch('/api/admin/organizations', { credentials: 'include' });
      if (!res.ok) return;
      allOrgs = await res.json();
      populateOrgSelect();
    } catch (_) {}
  }

  function populateOrgSelect(exclude = []) {
    const sel = document.getElementById('org-select');
    const excludeIds = new Set(exclude.map((o) => o.id));
    sel.innerHTML = '<option value="">— Add an organization —</option>' +
      allOrgs
        .filter((o) => !excludeIds.has(o.id))
        .map((o) => `<option value="${o.id}">${o.name}</option>`)
        .join('');
  }

  // ── Render table ──────────────────────────────────────────────────────────

  function roleChip(u) {
    if (u.is_admin) return '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-amber-100 text-amber-800 whitespace-nowrap">Super admin</span>';
    if (u.org_access_enabled) return '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-emerald-100 text-emerald-800 whitespace-nowrap">Org editor</span>';
    return '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-500 whitespace-nowrap">No access</span>';
  }

  function statusChip(status) {
    if (status === 'active')  return '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-700 whitespace-nowrap">Active</span>';
    if (status === 'invited') return '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 whitespace-nowrap">Invite sent</span>';
    return '<span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800 whitespace-nowrap">Pending invite</span>';
  }

  function orgsCell(u) {
    if (u.is_admin) return '<span class="text-sm text-gray-400">All</span>';
    if (!u.org_access_enabled || !u.organizations?.length) return '<span class="text-sm text-gray-400">None assigned</span>';
    return u.organizations.map((o) => `<div class="text-sm text-gray-700 leading-snug">${o.name}</div>`).join('');
  }

  function renderUsers() {
    const container = document.getElementById('users-container');
    if (!users.length) {
      container.innerHTML = '<p class="muted">No users yet. Click "Add user" to grant access.</p>';
      return;
    }

    container.innerHTML = `
      <div class="dashboard-table-container">
        <table class="w-full border border-gray-200 rounded-lg overflow-hidden sortable-table">
          <thead class="bg-gray-100">
            <tr>
              <th class="p-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
              <th class="p-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Role</th>
              <th class="p-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Organizations</th>
              <th class="p-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th class="p-3" data-sort-method="none"></th>
            </tr>
          </thead>
          <tbody>
            ${users.map((u) => {
              const isPrimary = u.email === PRIMARY_ADMIN_EMAIL;
              const canInvite = u.account_status !== 'active';
              return `
                <tr class="border-t border-gray-200 hover:bg-gray-50">
                  <td class="p-3 align-top font-medium text-sm">${u.email ?? '<em class="text-gray-400">unknown</em>'}</td>
                  <td class="p-3 align-top">${roleChip(u)}</td>
                  <td class="p-3 align-top">${orgsCell(u)}</td>
                  <td class="p-3 align-top">${statusChip(u.account_status)}</td>
                  <td class="p-3 align-top">
                    <span style="display:inline-flex;gap:0.3rem;align-items:center;">
                      <button type="button" class="icon-btn btn-edit" onclick="openEditModal('${u.user_id}')" aria-label="Edit permissions" style="padding:0.5rem;min-width:auto;height:auto;">
                        <span class="material-symbols-outlined" style="font-size:1.2rem;">edit</span>
                        <span class="tooltip">Edit permissions</span>
                      </button>
                      ${canInvite ? `
                      <button type="button" class="icon-btn btn-approve" onclick="openInviteModal('${u.user_id}')" aria-label="${u.account_status === 'invited' ? 'Resend invite' : 'Send invite'}" style="padding:0.5rem;min-width:auto;height:auto;">
                        <span class="material-symbols-outlined" style="font-size:1.2rem;">send</span>
                        <span class="tooltip">${u.account_status === 'invited' ? 'Resend invite' : 'Send invite'}</span>
                      </button>` : `
                      <span class="inline-flex items-center justify-center text-green-500 opacity-40" style="width:2.1rem;height:2.1rem;" title="Already active — can log in at /login">
                        <span class="material-symbols-outlined" style="font-size:1.2rem;">check_circle</span>
                      </span>`}
                      <button
                        type="button"
                        class="icon-btn btn-reject"
                        onclick="confirmRemove('${u.user_id}', '${(u.email ?? '').replace(/'/g, "\\'")}')"
                        title="${isPrimary ? 'Primary admin cannot be removed' : 'Remove access'}"
                        aria-label="${isPrimary ? 'Cannot remove primary admin' : 'Remove access'}"
                        ${isPrimary ? 'disabled' : ''}
                        style="padding:0.5rem;min-width:auto;height:auto;"
                      >
                        <span class="material-symbols-outlined" style="font-size:1.2rem;">person_remove</span>
                        <span class="tooltip">${isPrimary ? 'Cannot remove' : 'Remove access'}</span>
                      </button>
                    </span>
                  </td>
                </tr>
              `;
            }).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  // ── Modal: Add ────────────────────────────────────────────────────────────

  window.openAddUserModal = function () {
    editingUserId = null;
    editingUserOrgs = [];

    document.getElementById('modal-title').textContent = 'Add user';
    document.getElementById('email-field').style.display = '';
    document.getElementById('form-email').value = '';
    document.getElementById('form-email').required = true;
    document.getElementById('form-user-id').value = '';
    document.getElementById('role-org-editor').checked = true;
    document.getElementById('orgs-field').style.display = 'none';
    hideFormError();

    document.getElementById('user-modal').showModal();
  };

  // ── Modal: Edit ───────────────────────────────────────────────────────────

  window.openEditModal = async function (userId) {
    const u = users.find((u) => u.user_id === userId);
    if (!u) return;

    editingUserId = userId;
    editingUserOrgs = [...(u.organizations ?? [])];

    document.getElementById('modal-title').textContent = u.email ?? userId;
    document.getElementById('email-field').style.display = 'none';
    document.getElementById('form-email').required = false;
    document.getElementById('form-user-id').value = userId;
    hideFormError();

    const role = u.is_admin ? 'super_admin' : 'org_editor';
    document.querySelector(`input[name="role"][value="${role}"]`).checked = true;

    syncOrgsFieldVisibility();
    renderOrgsList();
    populateOrgSelect(editingUserOrgs);

    document.getElementById('user-modal').showModal();
  };

  window.closeUserModal = function () {
    document.getElementById('user-modal').close();
  };

  // ── Orgs section (inside modal) ───────────────────────────────────────────

  function renderOrgsList() {
    const el = document.getElementById('orgs-list');
    if (!editingUserOrgs.length) {
      el.innerHTML = '<p class="muted" style="margin-bottom:0.5rem">No organizations assigned yet.</p>';
      return;
    }
    el.innerHTML = editingUserOrgs
      .map(
        (o) => `
        <div class="assigned-org">
          <span>${o.name}</span>
          <button type="button" class="remove-org-btn" onclick="removeOrgFromUser('${o.id}', '${o.name.replace(/'/g, "\\'")}')">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
      `
      )
      .join('');
  }

  window.addOrgToUser = async function () {
    const sel = document.getElementById('org-select');
    const orgId = sel.value;
    if (!orgId || !editingUserId) return;

    const org = allOrgs.find((o) => o.id === orgId);
    if (!org) return;

    try {
      const res = await fetch('/api/admin/user-orgs', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: editingUserId, organization_id: orgId }),
      });
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? 'Failed to add org');
      }
      editingUserOrgs.push({ id: org.id, name: org.name });
      renderOrgsList();
      populateOrgSelect(editingUserOrgs);
      sel.value = '';
      // Refresh the main table row in memory so it reflects immediately on close
      const u = users.find((u) => u.user_id === editingUserId);
      if (u) u.organizations = [...editingUserOrgs];
    } catch (err) {
      showFormError(err.message);
    }
  };

  window.removeOrgFromUser = async function (orgId, orgName) {
    if (!confirm(`Remove access to "${orgName}"?`)) return;

    try {
      const res = await fetch(
        `/api/admin/user-orgs?user_id=${encodeURIComponent(editingUserId)}&organization_id=${encodeURIComponent(orgId)}`,
        { method: 'DELETE', credentials: 'include' }
      );
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? 'Failed to remove org');
      }
      editingUserOrgs = editingUserOrgs.filter((o) => o.id !== orgId);
      renderOrgsList();
      populateOrgSelect(editingUserOrgs);
      const u = users.find((u) => u.user_id === editingUserId);
      if (u) u.organizations = [...editingUserOrgs];
    } catch (err) {
      showFormError(err.message);
    }
  };

  // ── Form submit ───────────────────────────────────────────────────────────

  window.handleUserFormSubmit = async function (e) {
    e.preventDefault();
    const form = e.target;
    const submitBtn = document.getElementById('form-submit');

    hideFormError();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving…';

    const roleValue = form.querySelector('input[name="role"]:checked')?.value;
    const is_admin = roleValue === 'super_admin';
    const org_access_enabled = roleValue === 'org_editor';

    try {
      let res;
      if (editingUserId) {
        res = await fetch('/api/admin/users', {
          method: 'PUT',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: editingUserId, is_admin, org_access_enabled }),
        });
      } else {
        const email = document.getElementById('form-email').value.trim();
        res = await fetch('/api/admin/users', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, is_admin, org_access_enabled }),
        });
      }

      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? `Server error ${res.status}`);
      }

      const result = await res.json().catch(() => ({}));
      document.getElementById('user-modal').close();
      await loadUsers();

      if (!editingUserId) {
        showPageBanner(`User ${result.email} created. Set their permissions and org access, then click the send (✈) button to invite them.`);
      }
    } catch (err) {
      showFormError(err.message);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Save';
    }
  };

  // ── Send invite ───────────────────────────────────────────────────────────

  let invitingUserId = null;

  window.openInviteModal = function (userId) {
    const u = users.find((u) => u.user_id === userId);
    if (!u) return;
    invitingUserId = userId;

    const roleLabel = u.is_admin
      ? 'Super admin — full access to the admin panel'
      : u.org_access_enabled
        ? `Org editor — can edit events &amp; announcements for: ${
            u.organizations.length
              ? u.organizations.map((o) => o.name).join(', ')
              : '<em>no organizations assigned yet</em>'
          }`
        : 'No access assigned yet';

    const instructions = u.is_admin
      ? `<li>View and manage all events, announcements, locations, and organizations</li>
         <li>Approve pending events and publish announcements</li>
         <li>Manage user permissions</li>`
      : `<li>View and edit events &amp; announcements for your assigned organization(s)</li>
         <li>Submit events for approval (you cannot approve your own)</li>
         <li>Create new locations for your events</li>
         <li>You will <strong>not</strong> be able to approve/publish content — that requires a super admin</li>`;

    document.getElementById('invite-preview').innerHTML = `
      <div class="invite-user-info">
        <div class="invite-email">${u.email}</div>
        <div class="invite-role">${roleLabel}</div>
      </div>
      <p class="invite-desc">Clicking <strong>Send invite email</strong> will email ${u.email} a link to set their password and access the admin panel at <code>${siteOrigin}/admin</code>.</p>
      <div class="invite-what">
        <p class="invite-what-title">They will be able to:</p>
        <ul>${instructions}</ul>
      </div>
    `;

    document.getElementById('invite-error').style.display = 'none';
    document.getElementById('invite-send-btn').disabled = false;
    document.getElementById('invite-send-btn').textContent = 'Send invite email';

    document.getElementById('invite-modal').showModal();
  };

  window.sendInviteConfirmed = async function () {
    const btn = document.getElementById('invite-send-btn');
    const errEl = document.getElementById('invite-error');
    btn.disabled = true;
    btn.textContent = 'Sending…';
    errEl.style.display = 'none';

    try {
      const res = await fetch('/api/admin/send-invite', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: invitingUserId }),
      });
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? 'Failed to send invite');
      }
      document.getElementById('invite-modal').close();
      await loadUsers();
      const u = users.find((u) => u.user_id === invitingUserId);
      showPageBanner(`Invite sent to ${u?.email ?? invitingUserId}.`);
    } catch (err) {
      errEl.textContent = err.message;
      errEl.style.display = '';
      btn.disabled = false;
      btn.textContent = 'Send invite email';
    }
  };

  // ── Remove user ───────────────────────────────────────────────────────────

  window.confirmRemove = async function (userId, email) {
    if (!confirm(`Remove all admin access for ${email || userId}?\n\nThis cannot be undone.`)) return;
    try {
      const res = await fetch(`/api/admin/users?user_id=${encodeURIComponent(userId)}`, {
        method: 'DELETE',
        credentials: 'include',
      });
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? `Server error ${res.status}`);
      }
      await loadUsers();
    } catch (err) {
      alert('Error: ' + err.message);
    }
  };

  // ── Helpers ───────────────────────────────────────────────────────────────

  function showPageBanner(msg) {
    const el = document.getElementById('page-banner');
    el.textContent = msg;
    el.style.display = '';
    setTimeout(() => { el.style.display = 'none'; }, 6000);
  }

  function showFormError(msg) {
    const el = document.getElementById('form-error');
    el.textContent = msg;
    el.style.display = '';
  }

  function hideFormError() {
    const el = document.getElementById('form-error');
    el.textContent = '';
    el.style.display = 'none';
  }

  // ── Init ──────────────────────────────────────────────────────────────────

  document.addEventListener('DOMContentLoaded', () => {
    loadUsers();
    loadOrgs();
    loadAllowlist();
  });

  // ── Allowlist ─────────────────────────────────────────────────────────────

  let allowlist = [];

  async function loadAllowlist() {
    const loading = document.getElementById('allowlist-loading');
    const container = document.getElementById('allowlist-container');
    try {
      const res = await fetch('/api/admin/email-allowlist', { credentials: 'include' });
      if (!res.ok) throw new Error('Failed to load allowlist');
      allowlist = await res.json();
      renderAllowlist();
    } catch (err) {
      container.innerHTML = `<p class="error-text">${err.message}</p>`;
    } finally {
      loading.classList.add('hidden');
    }
  }

  function renderAllowlist() {
    const container = document.getElementById('allowlist-container');
    if (!allowlist.length) {
      container.innerHTML = '<p class="muted">No emails on the allowlist yet.</p>';
      return;
    }
    container.innerHTML = `
      <table class="w-full border border-gray-200 rounded-lg overflow-hidden sortable-table">
        <thead class="bg-gray-100">
          <tr>
            <th class="p-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Email</th>
            <th class="p-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Added</th>
            <th class="p-3" data-sort-method="none"></th>
          </tr>
        </thead>
        <tbody>
          ${allowlist.map((entry) => `
            <tr class="border-t border-gray-200 hover:bg-gray-50">
              <td class="p-3 text-sm font-medium">${entry.email}</td>
              <td class="p-3 text-sm text-gray-500">${new Date(entry.created_at).toLocaleDateString()}</td>
              <td class="p-3">
                <button type="button" class="icon-btn btn-reject" onclick="removeFromAllowlist('${entry.email.replace(/'/g, "\\'")}')" aria-label="Remove from allowlist" style="padding:0.5rem;min-width:auto;height:auto;">
                  <span class="material-symbols-outlined" style="font-size:1.2rem;">close</span>
                  <span class="tooltip">Remove</span>
                </button>
              </td>
            </tr>
          `).join('')}
        </tbody>
      </table>
    `;
  }

  window.addToAllowlist = async function () {
    const input = document.getElementById('allowlist-email-input');
    const email = input.value.trim().toLowerCase();
    if (!email) return;

    try {
      const res = await fetch('/api/admin/email-allowlist', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? 'Failed to add email');
      }
      input.value = '';
      await loadAllowlist();
    } catch (err) {
      alert('Error: ' + err.message);
    }
  };

  window.removeFromAllowlist = async function (email) {
    if (!confirm(`Remove ${email} from the signup allowlist?`)) return;
    try {
      const res = await fetch(
        `/api/admin/email-allowlist?email=${encodeURIComponent(email)}`,
        { method: 'DELETE', credentials: 'include' }
      );
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? 'Failed to remove');
      }
      await loadAllowlist();
    } catch (err) {
      alert('Error: ' + err.message);
    }
  };

  // Allow pressing Enter in the allowlist input
  document.getElementById('allowlist-email-input')?.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') { e.preventDefault(); window.addToAllowlist(); }
  });
</script>

