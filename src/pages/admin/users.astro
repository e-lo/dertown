---
import AdminLayout from '../../components/AdminLayout.astro';
import { getSessionFromCookies } from '../../lib/session';
import { checkAdminAccess } from '../../lib/session';

const cookieHeader = Astro.request.headers.get('cookie') ?? '';
const { session } = await getSessionFromCookies({ cookieHeader });
if (!session) {
  const redirectTo = Astro.url.pathname + Astro.url.search;
  return Astro.redirect(`/login?redirect=${encodeURIComponent(redirectTo)}`);
}

const { role } = await checkAdminAccess({ cookieHeader });
if (role !== 'super_admin') {
  return Astro.redirect('/admin');
}

const userEmail = session.user?.email || 'Admin';
const siteOrigin = Astro.url.origin;
---

<AdminLayout title="User Permissions" userEmail={userEmail}>
  <Fragment slot="actions">
    <button
      type="button"
      onclick="openAddUserModal()"
      class="icon-btn btn-save"
      aria-label="Add user"
    >
      <span class="material-symbols-outlined text-2xl">person_add</span>
      <span class="tooltip">Add user</span>
    </button>
  </Fragment>

  <div class="page-intro">
    <p>
      Manage who can access the admin panel. <strong>Super admins</strong> have full access.
      <strong>Org editors</strong> can view and edit events &amp; announcements only for their
      assigned organizations.
    </p>
  </div>

  <div id="page-banner" class="page-banner" style="display:none"></div>
  <div id="users-loading" class="loading">Loading users…</div>
  <div id="users-container"></div>
</AdminLayout>

<!-- ── Add / Edit User Modal ──────────────────────────────────────────────── -->
<dialog id="user-modal" class="modal-dialog">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="modal-title" class="modal-title">Add user</h2>
      <button type="button" onclick="closeUserModal()" class="modal-close" aria-label="Close">
        <span class="material-symbols-outlined">close</span>
      </button>
    </div>

    <form id="user-form" onsubmit="handleUserFormSubmit(event)">
      <input type="hidden" id="form-user-id" value="" />

      <!-- Email (shown only when adding a new user) -->
      <div class="field" id="email-field">
        <label for="form-email" class="field-label">Email address</label>
        <input
          type="email"
          id="form-email"
          name="email"
          class="field-input"
          placeholder="user@example.com"
        />
        <p class="field-hint">
          If they don't have an account yet, an invite email will be sent automatically.
        </p>
      </div>

      <!-- Role -->
      <div class="field">
        <label class="field-label">Role</label>
        <div class="role-options">
          <label class="role-option">
            <input type="radio" name="role" value="org_editor" id="role-org-editor" checked />
            <span class="role-label">
              <strong>Org editor</strong>
              <span class="role-desc">Can edit events &amp; announcements for their assigned organizations</span>
            </span>
          </label>
          <label class="role-option">
            <input type="radio" name="role" value="super_admin" id="role-super-admin" />
            <span class="role-label">
              <strong>Super admin</strong>
              <span class="role-desc">Full access — approve, publish, manage all orgs and users</span>
            </span>
          </label>
        </div>
      </div>

      <!-- Org assignments (shown when editing an org_editor) -->
      <div class="field" id="orgs-field" style="display:none">
        <label class="field-label">Organization access</label>
        <div id="orgs-list" class="orgs-list"></div>
        <div class="add-org-row">
          <select id="org-select" class="field-input field-select">
            <option value="">— Add an organization —</option>
          </select>
          <button type="button" onclick="addOrgToUser()" class="btn-add-org">Add</button>
        </div>
      </div>

      <div id="form-error" class="form-error" style="display:none"></div>

      <div class="modal-footer">
        <button type="button" onclick="closeUserModal()" class="btn-cancel">Cancel</button>
        <button type="submit" id="form-submit" class="btn-primary">Save</button>
      </div>
    </form>
  </div>
</dialog>

<script define:vars={{ siteOrigin }}>
  const PRIMARY_ADMIN_EMAIL = 'dertownleavenworth@gmail.com';

  let users = [];
  let allOrgs = [];       // all organizations for the dropdown
  let editingUserId = null;
  let editingUserOrgs = []; // orgs currently assigned to the user being edited

  // ── Bootstrap ─────────────────────────────────────────────────────────────

  // Wire role radio buttons to show/hide org section
  document.querySelectorAll('input[name="role"]').forEach((el) => {
    el.addEventListener('change', syncOrgsFieldVisibility);
  });

  function syncOrgsFieldVisibility() {
    const role = document.querySelector('input[name="role"]:checked')?.value;
    const orgsField = document.getElementById('orgs-field');
    orgsField.style.display = (role === 'org_editor' && editingUserId) ? '' : 'none';
  }

  // ── Load data ─────────────────────────────────────────────────────────────

  async function loadUsers() {
    const loading = document.getElementById('users-loading');
    const container = document.getElementById('users-container');
    try {
      const res = await fetch('/api/admin/users', { credentials: 'include' });
      if (!res.ok) throw new Error('Failed to load users');
      users = await res.json();
      renderUsers();
    } catch (err) {
      container.innerHTML = `<p class="error-text">${err.message}</p>`;
    } finally {
      loading.classList.add('hidden');
    }
  }

  async function loadOrgs() {
    try {
      const res = await fetch('/api/admin/organizations', { credentials: 'include' });
      if (!res.ok) return;
      allOrgs = await res.json();
      populateOrgSelect();
    } catch (_) {}
  }

  function populateOrgSelect(exclude = []) {
    const sel = document.getElementById('org-select');
    const excludeIds = new Set(exclude.map((o) => o.id));
    sel.innerHTML = '<option value="">— Add an organization —</option>' +
      allOrgs
        .filter((o) => !excludeIds.has(o.id))
        .map((o) => `<option value="${o.id}">${o.name}</option>`)
        .join('');
  }

  // ── Render table ──────────────────────────────────────────────────────────

  function roleChip(u) {
    if (u.is_admin) return '<span class="chip chip-admin">Super admin</span>';
    if (u.org_access_enabled) return '<span class="chip chip-editor">Org editor</span>';
    return '<span class="chip chip-none">No access</span>';
  }

  function orgsCell(u) {
    if (u.is_admin) return '<span class="muted">All</span>';
    if (!u.org_access_enabled || !u.organizations?.length) return '<span class="muted">None assigned</span>';
    return u.organizations
      .map((o) => `<span class="org-chip">${o.name}</span>`)
      .join('');
  }

  function renderUsers() {
    const container = document.getElementById('users-container');
    if (!users.length) {
      container.innerHTML = '<p class="muted">No users yet. Click "Add user" to grant access.</p>';
      return;
    }

    container.innerHTML = `
      <table class="users-table">
        <thead>
          <tr>
            <th>Email</th>
            <th>Role</th>
            <th>Organizations</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          ${users.map((u) => {
            const isPrimary = u.email === PRIMARY_ADMIN_EMAIL;
            return `
              <tr>
                <td class="td-email">${u.email ?? '<em class="muted">unknown</em>'}</td>
                <td class="td-role">${roleChip(u)}</td>
                <td class="td-orgs">${orgsCell(u)}</td>
                <td class="td-actions">
                  <button
                    type="button"
                    class="action-btn"
                    onclick="openEditModal('${u.user_id}')"
                    title="Edit"
                  ><span class="material-symbols-outlined">edit</span></button>
                  <button
                    type="button"
                    class="action-btn action-btn-danger"
                    onclick="confirmRemove('${u.user_id}', '${(u.email ?? '').replace(/'/g, "\\'")}')"
                    title="${isPrimary ? 'Primary admin cannot be removed' : 'Remove access'}"
                    ${isPrimary ? 'disabled' : ''}
                  ><span class="material-symbols-outlined">person_remove</span></button>
                </td>
              </tr>
            `;
          }).join('')}
        </tbody>
      </table>
    `;
  }

  // ── Modal: Add ────────────────────────────────────────────────────────────

  window.openAddUserModal = function () {
    editingUserId = null;
    editingUserOrgs = [];

    document.getElementById('modal-title').textContent = 'Add user';
    document.getElementById('email-field').style.display = '';
    document.getElementById('form-email').value = '';
    document.getElementById('form-email').required = true;
    document.getElementById('form-user-id').value = '';
    document.getElementById('role-org-editor').checked = true;
    document.getElementById('orgs-field').style.display = 'none';
    hideFormError();

    document.getElementById('user-modal').showModal();
  };

  // ── Modal: Edit ───────────────────────────────────────────────────────────

  window.openEditModal = async function (userId) {
    const u = users.find((u) => u.user_id === userId);
    if (!u) return;

    editingUserId = userId;
    editingUserOrgs = [...(u.organizations ?? [])];

    document.getElementById('modal-title').textContent = u.email ?? userId;
    document.getElementById('email-field').style.display = 'none';
    document.getElementById('form-email').required = false;
    document.getElementById('form-user-id').value = userId;
    hideFormError();

    const role = u.is_admin ? 'super_admin' : 'org_editor';
    document.querySelector(`input[name="role"][value="${role}"]`).checked = true;

    syncOrgsFieldVisibility();
    renderOrgsList();
    populateOrgSelect(editingUserOrgs);

    document.getElementById('user-modal').showModal();
  };

  window.closeUserModal = function () {
    document.getElementById('user-modal').close();
  };

  // ── Orgs section (inside modal) ───────────────────────────────────────────

  function renderOrgsList() {
    const el = document.getElementById('orgs-list');
    if (!editingUserOrgs.length) {
      el.innerHTML = '<p class="muted" style="margin-bottom:0.5rem">No organizations assigned yet.</p>';
      return;
    }
    el.innerHTML = editingUserOrgs
      .map(
        (o) => `
        <div class="assigned-org">
          <span>${o.name}</span>
          <button type="button" class="remove-org-btn" onclick="removeOrgFromUser('${o.id}', '${o.name.replace(/'/g, "\\'")}')">
            <span class="material-symbols-outlined">close</span>
          </button>
        </div>
      `
      )
      .join('');
  }

  window.addOrgToUser = async function () {
    const sel = document.getElementById('org-select');
    const orgId = sel.value;
    if (!orgId || !editingUserId) return;

    const org = allOrgs.find((o) => o.id === orgId);
    if (!org) return;

    try {
      const res = await fetch('/api/admin/user-orgs', {
        method: 'POST',
        credentials: 'include',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ user_id: editingUserId, organization_id: orgId }),
      });
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? 'Failed to add org');
      }
      editingUserOrgs.push({ id: org.id, name: org.name });
      renderOrgsList();
      populateOrgSelect(editingUserOrgs);
      sel.value = '';
      // Refresh the main table row in memory so it reflects immediately on close
      const u = users.find((u) => u.user_id === editingUserId);
      if (u) u.organizations = [...editingUserOrgs];
    } catch (err) {
      showFormError(err.message);
    }
  };

  window.removeOrgFromUser = async function (orgId, orgName) {
    if (!confirm(`Remove access to "${orgName}"?`)) return;

    try {
      const res = await fetch(
        `/api/admin/user-orgs?user_id=${encodeURIComponent(editingUserId)}&organization_id=${encodeURIComponent(orgId)}`,
        { method: 'DELETE', credentials: 'include' }
      );
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? 'Failed to remove org');
      }
      editingUserOrgs = editingUserOrgs.filter((o) => o.id !== orgId);
      renderOrgsList();
      populateOrgSelect(editingUserOrgs);
      const u = users.find((u) => u.user_id === editingUserId);
      if (u) u.organizations = [...editingUserOrgs];
    } catch (err) {
      showFormError(err.message);
    }
  };

  // ── Form submit ───────────────────────────────────────────────────────────

  window.handleUserFormSubmit = async function (e) {
    e.preventDefault();
    const form = e.target;
    const submitBtn = document.getElementById('form-submit');

    hideFormError();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Saving…';

    const roleValue = form.querySelector('input[name="role"]:checked')?.value;
    const is_admin = roleValue === 'super_admin';
    const org_access_enabled = roleValue === 'org_editor';

    try {
      let res;
      if (editingUserId) {
        res = await fetch('/api/admin/users', {
          method: 'PUT',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ user_id: editingUserId, is_admin, org_access_enabled }),
        });
      } else {
        const email = document.getElementById('form-email').value.trim();
        res = await fetch('/api/admin/users', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, is_admin, org_access_enabled }),
        });
      }

      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? `Server error ${res.status}`);
      }

      const result = await res.json().catch(() => ({}));
      document.getElementById('user-modal').close();
      await loadUsers();

      // Let the admin know if an invite email was sent
      if (result.invited) {
        showPageBanner(`Invite sent to ${result.email}. They'll receive an email to set up their account.`);
      }
    } catch (err) {
      showFormError(err.message);
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Save';
    }
  };

  // ── Remove user ───────────────────────────────────────────────────────────

  window.confirmRemove = async function (userId, email) {
    if (!confirm(`Remove all admin access for ${email || userId}?\n\nThis cannot be undone.`)) return;
    try {
      const res = await fetch(`/api/admin/users?user_id=${encodeURIComponent(userId)}`, {
        method: 'DELETE',
        credentials: 'include',
      });
      if (!res.ok) {
        const b = await res.json().catch(() => ({}));
        throw new Error(b.error ?? `Server error ${res.status}`);
      }
      await loadUsers();
    } catch (err) {
      alert('Error: ' + err.message);
    }
  };

  // ── Helpers ───────────────────────────────────────────────────────────────

  function showPageBanner(msg) {
    const el = document.getElementById('page-banner');
    el.textContent = msg;
    el.style.display = '';
    setTimeout(() => { el.style.display = 'none'; }, 6000);
  }

  function showFormError(msg) {
    const el = document.getElementById('form-error');
    el.textContent = msg;
    el.style.display = '';
  }

  function hideFormError() {
    const el = document.getElementById('form-error');
    el.textContent = '';
    el.style.display = 'none';
  }

  // ── Init ──────────────────────────────────────────────────────────────────

  document.addEventListener('DOMContentLoaded', () => {
    loadUsers();
    loadOrgs();
  });
</script>

<style>
  .loading { text-align: center; padding: 2rem; color: #999; }
  .loading.hidden { display: none; }
  .hidden { display: none !important; }
  .muted { color: #9ca3af; font-size: 0.875rem; }
  .error-text { color: #dc2626; }

  /* Page banner (success messages) */
  .page-banner {
    background: #d1fae5;
    color: #065f46;
    border: 1px solid #a7f3d0;
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 1rem;
    font-size: 0.9rem;
  }

  /* Page intro */
  .page-intro {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    padding: 0.875rem 1.1rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: #475569;
    line-height: 1.5;
  }

  /* Table */
  .users-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    overflow: hidden;
    font-size: 0.9rem;
  }
  .users-table th {
    padding: 0.75rem 1.25rem;
    background: #f9fafb;
    border-bottom: 1px solid #e5e7eb;
    text-align: left;
    font-weight: 600;
    color: #374151;
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .users-table td {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid #f3f4f6;
    vertical-align: middle;
  }
  .users-table tr:last-child td { border-bottom: none; }
  .users-table tbody tr:hover td { background: #fafafa; }

  .td-email { font-weight: 500; }
  .td-orgs { display: flex; flex-wrap: wrap; gap: 0.3rem; align-items: center; }
  .td-actions { display: flex; gap: 0.4rem; align-items: center; }

  /* Chips */
  .chip {
    display: inline-block;
    padding: 0.25rem 0.65rem;
    border-radius: 9999px;
    font-size: 0.78rem;
    font-weight: 600;
    white-space: nowrap;
  }
  .chip-admin  { background: #fef3c7; color: #92400e; }
  .chip-editor { background: #d1fae5; color: #065f46; }
  .chip-none   { background: #f3f4f6; color: #9ca3af; }

  .org-chip {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 9999px;
    background: #e0f2fe;
    color: #0369a1;
    font-size: 0.8rem;
    white-space: nowrap;
  }

  /* Action buttons */
  .action-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.1rem;
    height: 2.1rem;
    border-radius: 6px;
    border: 1px solid #e5e7eb;
    background: white;
    color: #374151;
    cursor: pointer;
    text-decoration: none;
  }
  .action-btn:hover { background: #f3f4f6; }
  .action-btn:disabled { opacity: 0.35; cursor: not-allowed; }
  .action-btn-danger { color: #dc2626; }
  .action-btn-danger:hover:not(:disabled) { background: #fee2e2; border-color: #fecaca; }
  .action-btn .material-symbols-outlined { font-size: 1.1rem; }

  /* ── Modal ── */
  .modal-dialog {
    border: none;
    border-radius: 12px;
    padding: 0;
    width: min(520px, 95vw);
    box-shadow: 0 20px 60px rgba(0,0,0,0.18);
  }
  .modal-dialog::backdrop { background: rgba(0,0,0,0.35); }
  .modal-content { padding: 1.75rem; }
  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
  }
  .modal-title { font-size: 1.1rem; font-weight: 700; margin: 0; }
  .modal-close {
    background: none;
    border: none;
    cursor: pointer;
    color: #6b7280;
    display: flex;
    align-items: center;
    padding: 0.25rem;
    border-radius: 4px;
  }
  .modal-close:hover { color: #111; background: #f3f4f6; }
  .modal-footer {
    display: flex;
    justify-content: flex-end;
    gap: 0.75rem;
    margin-top: 1.75rem;
    padding-top: 1rem;
    border-top: 1px solid #f3f4f6;
  }

  /* Form fields */
  .field { margin-bottom: 1.25rem; }
  .field-label {
    display: block;
    font-weight: 600;
    font-size: 0.85rem;
    color: #374151;
    margin-bottom: 0.4rem;
  }
  .field-input {
    width: 100%;
    padding: 0.55rem 0.75rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    font-size: 0.9rem;
    outline: none;
    box-sizing: border-box;
  }
  .field-input:focus { border-color: #6366f1; box-shadow: 0 0 0 2px rgba(99,102,241,0.15); }
  .field-select { cursor: pointer; }
  .field-hint { font-size: 0.78rem; color: #9ca3af; margin-top: 0.3rem; }
  .field-hint a { color: #6366f1; }

  .form-error {
    background: #fee2e2;
    color: #b91c1c;
    padding: 0.6rem 0.85rem;
    border-radius: 6px;
    font-size: 0.85rem;
    margin-top: 0.75rem;
    line-height: 1.45;
  }

  /* Role options */
  .role-options { display: flex; flex-direction: column; gap: 0.5rem; }
  .role-option {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    padding: 0.7rem 0.85rem;
    border: 1px solid #e5e7eb;
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.1s, background 0.1s;
  }
  .role-option:has(input:checked) { border-color: #6366f1; background: #f5f3ff; }
  .role-option input[type="radio"] { margin-top: 0.2rem; accent-color: #6366f1; flex-shrink: 0; }
  .role-label { display: flex; flex-direction: column; gap: 0.1rem; font-size: 0.875rem; }
  .role-desc { color: #6b7280; font-size: 0.8rem; }

  /* Org assignment in modal */
  .orgs-list { display: flex; flex-direction: column; gap: 0.35rem; margin-bottom: 0.6rem; }
  .assigned-org {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.45rem 0.75rem;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 6px;
    font-size: 0.875rem;
  }
  .remove-org-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: #6b7280;
    display: flex;
    align-items: center;
    padding: 0.1rem;
    border-radius: 3px;
  }
  .remove-org-btn:hover { color: #dc2626; background: #fee2e2; }
  .remove-org-btn .material-symbols-outlined { font-size: 1rem; }

  .add-org-row {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .add-org-row .field-select { flex: 1; }
  .btn-add-org {
    padding: 0.5rem 0.85rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: white;
    color: #374151;
    cursor: pointer;
    font-size: 0.875rem;
    white-space: nowrap;
  }
  .btn-add-org:hover { background: #f3f4f6; }

  /* Buttons */
  .btn-cancel {
    padding: 0.5rem 1rem;
    border: 1px solid #d1d5db;
    border-radius: 6px;
    background: white;
    color: #374151;
    cursor: pointer;
    font-size: 0.875rem;
  }
  .btn-cancel:hover { background: #f9fafb; }
  .btn-primary {
    padding: 0.5rem 1.25rem;
    border: none;
    border-radius: 6px;
    background: #6366f1;
    color: white;
    cursor: pointer;
    font-size: 0.875rem;
    font-weight: 600;
  }
  .btn-primary:hover { background: #4f46e5; }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
</style>
