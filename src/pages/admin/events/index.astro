---
import AdminLayout from '../../../components/AdminLayout.astro';
import { getSessionFromCookies } from '../../../lib/session';

const { session } = await getSessionFromCookies(Astro.cookies);
if (!session) {
  const redirectTo = Astro.url.pathname + Astro.url.search;
  return Astro.redirect(`/login?redirect=${encodeURIComponent(redirectTo)}`);
}
const userEmail = session.user?.email || 'Admin';
---

<AdminLayout title="Events" userEmail={userEmail}>
  <Fragment slot="actions">
    <a href="/admin/events/new" class="icon-btn btn-create" aria-label="Create New Event">
      <span class="material-symbols-outlined text-2xl">add</span>
      <span class="tooltip">Create New Event</span>
    </a>
  </Fragment>

  <div class="mb-4 flex flex-wrap items-center gap-4">
    <div class="relative max-w-md flex-1 min-w-[200px]">
      <label for="event-search" class="sr-only">Search events</label>
      <input type="text" id="event-search" class="form-input-base w-full" placeholder="Type to search any event..." autocomplete="off" />
      <div id="event-search-dropdown" class="autocomplete-dropdown hidden"></div>
    </div>
    <p class="text-sm text-gray-500">Search opens any event by title. List shows approved, pending, and cancelled events in the next month.</p>
  </div>
  <div id="events-loading" class="loading">Loading events...</div>
  <div id="events-container"></div>
</AdminLayout>

<script>
  import {
    renderSortableTable,
    textColumn,
    statusColumn,
    lastEditedColumn,
    derivedColumn,
    actionsColumn,
  } from '../../../lib/admin/sortable-table';

  type ListEvent = {
    id: string;
    title?: string;
    start_date?: string;
    start_time?: string;
    status?: string;
    updated_at?: string;
    location?: { name?: string };
    organization?: { name?: string };
    primary_tag?: { name?: string };
  };

  const EVENT_COLUMNS = [
    textColumn<ListEvent>('title', 'Title', 'title'),
    textColumn<ListEvent>('date', 'Date', 'start_date'),
    derivedColumn<ListEvent>(
      'time',
      'Time',
      (e) => (e.start_time ? String(e.start_time).substring(0, 5) : '—'),
      (e) => e.start_time ?? ''
    ),
    textColumn<ListEvent>('location', 'Location', (e) => e.location?.name),
    textColumn<ListEvent>('organization', 'Organization', (e) => e.organization?.name),
    textColumn<ListEvent>('tag', 'Tag', (e) => e.primary_tag?.name),
    statusColumn<ListEvent>('status', 'Status', 'status'),
    lastEditedColumn<ListEvent>('lastEdited', 'Last edited'),
    actionsColumn<ListEvent>(
      'actions',
      (e) => `/events/${e.id}`,
      (e) => ({ href: `/admin/events/${e.id}` })
    ),
  ];

  let events: ListEvent[] = [];
  let searchTimeout: number | null = null;

  async function loadEvents() {
    const el = document.getElementById('events-loading');
    const container = document.getElementById('events-container');
    if (!el || !container) return;
    try {
      const res = await fetch('/api/admin/events/list?days=30', { credentials: 'include' });
      if (res.status === 401) {
        window.location.href = `/login?redirect=${encodeURIComponent(window.location.pathname)}`;
        return;
      }
      if (!res.ok) throw new Error('Failed to load events');
      const data = await res.json();
      events = /** @type {ListEvent[]} */ (data.events || []);
      renderEvents();
    } catch (err) {
      const msg = err instanceof Error ? err.message : 'Failed to load events';
      container.innerHTML = '<p class="text-red-600">' + msg + '</p>';
    } finally {
      el.classList.add('hidden');
    }
  }

  function renderEvents() {
    const container = document.getElementById('events-container');
    renderSortableTable(container, {
      data: events,
      columns: EVENT_COLUMNS,
      initialSortColumn: 'date',
      maxRows: 100,
      expandable: true,
      emptyMessage: 'No events in the next month.',
    });
  }

  // Event search autocomplete
  const searchInput = document.getElementById('event-search');
  const dropdown = document.getElementById('event-search-dropdown');
  if (searchInput && dropdown && searchInput instanceof HTMLInputElement) {
    const inputEl = searchInput;
    searchInput.addEventListener('input', () => {
      const q = inputEl.value.trim();
      if (q.length < 2) {
        dropdown.classList.add('hidden');
        dropdown.classList.remove('block');
        return;
      }
      if (searchTimeout !== null) {
        clearTimeout(searchTimeout);
      }
      searchTimeout = window.setTimeout(async () => {
        try {
          const res = await fetch('/api/admin/events/search?q=' + encodeURIComponent(q), { credentials: 'include' });
          if (!res.ok) return;
          const list = await res.json();
          if (!Array.isArray(list) || list.length === 0) {
            dropdown.innerHTML = '<div class="autocomplete-dropdown-item">No events found</div>';
          } else {
            dropdown.innerHTML = list.map(ev => {
              const dateStr = ev.start_date ? new Date(ev.start_date).toLocaleDateString() : '';
              const timeStr = ev.start_time ? String(ev.start_time).substring(0, 5) : '';
              const sub = [dateStr, timeStr].filter(Boolean).join(' ');
              const escaped = (ev.title || '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/'/g, '&#39;');
              return '<div class="autocomplete-dropdown-item" data-id="' + ev.id + '">' + escaped + (sub ? ' <span class="text-gray-500">' + sub + '</span>' : '') + '</div>';
            }).join('');
          }
          dropdown.classList.remove('hidden');
          dropdown.classList.add('block');
          dropdown.querySelectorAll('.autocomplete-dropdown-item[data-id]').forEach(item => {
            item.addEventListener('click', () => {
              const id = item.getAttribute('data-id');
              if (id) window.location.href = '/admin/events/' + id;
            });
          });
        } catch {
          dropdown.classList.add('hidden');
        }
      }, 200);
    });
    searchInput.addEventListener('focus', () => {
      if (inputEl.value.trim().length >= 2 && dropdown.innerHTML) {
        dropdown.classList.remove('hidden');
        dropdown.classList.add('block');
      }
    });
    document.addEventListener('click', (e) => {
      const target = e.target instanceof Node ? e.target : null;
      if (target && !inputEl.contains(target) && !dropdown.contains(target)) {
        dropdown.classList.add('hidden');
        dropdown.classList.remove('block');
      }
    });
  }

  loadEvents();
</script>
