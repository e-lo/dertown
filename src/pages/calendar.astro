---
export const prerender = false;

import Layout from '../components/Layout.astro';
import CalendarV2 from '../components/CalendarV2.astro';

const initialTag = Astro.url.searchParams.get('tag') || undefined;
---

<Layout
  title="Event Calendar - Der Town"
  description="View upcoming community events in Der Town. Find local activities, festivals, meetings, and community gatherings all in one place."
>
  <div class="container mx-auto px-4 py-8">
    <CalendarV2 defaultView="week" showSearch={true} showCategoryFilter={true} initialTag={initialTag} />
  </div>
</Layout>
