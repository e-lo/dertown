---
export const prerender = false;

import Layout from '../../components/Layout.astro';
import GroupedEventList from '../../components/GroupedEventList.astro';
import { buildEventMapState, normalizeMapEvents } from '../../lib/event-map';
import { db, getTodayLocale } from '../../lib/supabase';

function formatDateLabel(dateString: string): string {
  const [year, month, day] = dateString.split('-').map(Number);
  return new Date(Date.UTC(year, month - 1, day)).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    timeZone: 'UTC',
  });
}

const mapDataResult = await db.events.getAllForMap();
const rawEvents = mapDataResult.data || [];
const allMapEvents = normalizeMapEvents(rawEvents);
const searchParams = new URL(Astro.url).searchParams;
const state = buildEventMapState(rawEvents, searchParams);
const requestedLocationId = searchParams.get('loc');
const initialSelectedLocationId =
  (requestedLocationId && state.groups.some((group) => group.id === requestedLocationId)
    ? requestedLocationId
    : '');
const initialSelectedLocation =
  state.groups.find((group) => group.id === initialSelectedLocationId) || null;
const initialOrgValue =
  state.organizations.find(
    (organization) =>
      organization.id === state.filters.selectedOrg || organization.slug === state.filters.selectedOrg
  )?.name || '';

const payload = JSON.stringify({
  baseDate: getTodayLocale(),
  events: allMapEvents,
  tags: state.tags,
  organizations: state.organizations,
  initialFilters: state.filters,
  initialSelectedLocationId,
  mapboxToken: import.meta.env.PUBLIC_MAPBOX_TOKEN || '',
}).replace(/</g, '\\u003c');
---

<Layout
  title="Events Map - Der Town"
  description="Browse upcoming community events across town with a map-first view and grouped venue results."
>
  <section class="map-view-shell py-8 sm:py-10">
    <div class="container-wide space-y-5">
      <section class="map-view-card map-stage">
        <div class="map-stage-head">
          <p class="map-stage-kicker">
            <span class="map-stage-eyebrow">Map View</span>
            <span class="map-stage-title">Upcoming events across town</span>
          </p>
        </div>

        <div class="map-canvas" id="event-map-canvas">
          <div id="event-map-gl" style="position:absolute;inset:0;z-index:0;"></div>
          <div class="map-overlay">
            <div class="overlay-row overlay-row-top">
              <div class="map-badge">
                <span class="material-symbols-outlined">travel_explore</span>
                Explore the town map
              </div>
              <div class="compact-actions">
                <button type="button" class="map-btn map-btn-ghost" id="event-map-reset">
                  Reset
                </button>
                <button type="button" class="map-btn map-btn-primary" id="event-map-copy-link">
                  Copy link
                </button>
              </div>
            </div>

            <div class="overlay-row overlay-row-filters">
              <div class="date-range-shell">
                <div class="date-range-head">
                    <span class="range-label">Dates</span>
                  <div class="range-summary">
                    <span id="event-map-start-label">{formatDateLabel(state.filters.startDate)}</span>
                    <span aria-hidden="true">to</span>
                    <span id="event-map-end-label">{formatDateLabel(state.filters.endDate)}</span>
                  </div>
                </div>
                <div class="double-range">
                  <div class="double-range-track"></div>
                  <div class="double-range-fill" id="event-map-range-fill"></div>
                  <input
                    id="event-map-start-offset"
                    type="range"
                    min="0"
                    max="21"
                    value={state.filters.fromOffset}
                  />
                  <input
                    id="event-map-end-offset"
                    type="range"
                    min="1"
                    max="30"
                    value={state.filters.toOffset}
                  />
                </div>
              </div>

              <div class="tag-pill-row" id="event-map-tag-filter">
                <button
                  type="button"
                  class={`tag-pill ${!state.filters.selectedTag ? 'is-active' : ''}`}
                  data-tag=""
                >
                  All
                </button>
                {state.tags.map((tag) => (
                  <button
                    type="button"
                    class={`tag-pill ${state.filters.selectedTag === tag.slug ? 'is-active' : ''}`}
                    data-tag={tag.slug}
                  >
                    {tag.name}
                  </button>
                ))}
              </div>

              <div class="org-filter-shell">
                <span class="material-symbols-outlined">search</span>
                <input
                  id="event-map-org-input"
                  type="text"
                  value={initialOrgValue}
                  list="event-map-org-options"
                  aria-label="Filter by organization"
                  placeholder="Organization"
                />
                <button
                  type="button"
                  class="org-clear"
                  id="event-map-org-clear"
                  aria-label="Clear organization filter"
                >
                  <span class="material-symbols-outlined">close</span>
                </button>
              </div>
              <datalist id="event-map-org-options">
                {state.organizations.map((organization) => <option value={organization.name} />)}
              </datalist>
            </div>
          </div>

          <div class="map-tools in-map">
            <button type="button" aria-label="Zoom in" id="event-map-zoom-in">+</button>
            <button type="button" aria-label="Zoom out" id="event-map-zoom-out">-</button>
            <button type="button" aria-label="Fit to results" id="event-map-fit">
              <span class="material-symbols-outlined">my_location</span>
            </button>
          </div>



          <div class="map-callout" id="event-map-callout">
            {initialSelectedLocation ? (
              <>
                <p class="map-callout-eyebrow">Selected location</p>
                <h3>{initialSelectedLocation.name}</h3>
                <p>{initialSelectedLocation.eventCount} events in the active window</p>
                <a href={`#location-${initialSelectedLocation.id}`}>Jump to grouped list</a>
              </>
            ) : (
              <>
                <p class="map-callout-eyebrow">No current matches</p>
                <h3>No venues match these filters</h3>
                <p>Adjust the date range, tags, or organization filter.</p>
              </>
            )}
          </div>
        </div>
      </section>

      <section class="map-view-card result-panel">
        <div class="panel-header">
          <div>
            <p class="panel-eyebrow">Showing <span id="event-map-event-count">{state.events.length}</span> events</p>
            <h2>Grouped venue list</h2>
          </div>
          <div class="result-summary-badges">
            <span><span id="event-map-location-count">{state.groups.length}</span> active locations</span>
            <span id="event-map-permalink">{Astro.url.pathname}{Astro.url.search}</span>
          </div>
        </div>

        <div id="event-map-list">
          {state.groups.length > 0 ? (
            <GroupedEventList
              groups={state.groups}
              selectedId={initialSelectedLocationId}
              className="result-list"
              idPrefix="location-"
            />
          ) : (
            <div class="empty-state">
              <h3>No matching events</h3>
              <p>Try widening the date range or clearing a filter.</p>
            </div>
          )}
        </div>
      </section>
    </div>
  </section>

  <script id="event-map-data" type="application/json" set:text={payload}></script>
  <script>
    import mapboxgl from 'mapbox-gl';
    import 'mapbox-gl/dist/mapbox-gl.css';

    document.addEventListener('DOMContentLoaded', () => {
      const dataElement = document.getElementById('event-map-data');
      if (!dataElement?.textContent) {
        console.error('[MAP] No data element found');
        return;
      }

      try {
        // Unescape HTML entities that Astro's set:text adds (e.g., &quot; -> ")
        const unescapedContent = dataElement.textContent
          .replace(/&quot;/g, '"')
          .replace(/&amp;/g, '&')
          .replace(/&lt;/g, '<')
          .replace(/&gt;/g, '>')
          .replace(/&#39;/g, "'");

        const payload = JSON.parse(unescapedContent);
      const allEvents = Array.isArray(payload.events) ? payload.events : [];
      const organizations = Array.isArray(payload.organizations) ? payload.organizations : [];

      const startInput = document.getElementById('event-map-start-offset');
      const endInput = document.getElementById('event-map-end-offset');
      const startLabel = document.getElementById('event-map-start-label');
      const endLabel = document.getElementById('event-map-end-label');
      const rangeFill = document.getElementById('event-map-range-fill');
      const tagFilter = document.getElementById('event-map-tag-filter');
      const orgInput = document.getElementById('event-map-org-input');
      const orgClear = document.getElementById('event-map-org-clear');
      const resetButton = document.getElementById('event-map-reset');
      const copyLinkButton = document.getElementById('event-map-copy-link');
      const permalink = document.getElementById('event-map-permalink');
      const eventCount = document.getElementById('event-map-event-count');
      const locationCount = document.getElementById('event-map-location-count');
      const listContainer = document.getElementById('event-map-list');
      const callout = document.getElementById('event-map-callout');
      const mapEl = document.getElementById('event-map-gl');
      const zoomInButton = document.getElementById('event-map-zoom-in');
      const zoomOutButton = document.getElementById('event-map-zoom-out');
      const fitButton = document.getElementById('event-map-fit');

      if (!(startInput instanceof HTMLInputElement) || !(endInput instanceof HTMLInputElement)) return;
      if (!(orgInput instanceof HTMLInputElement)) return;

      const state = {
        fromOffset: Number(payload.initialFilters?.fromOffset || 0),
        toOffset: Number(payload.initialFilters?.toOffset || 10),
        selectedTag: String(payload.initialFilters?.selectedTag || ''),
        selectedOrg: String(payload.initialFilters?.selectedOrg || ''),
        selectedLocationId: String(payload.initialSelectedLocationId || ''),
      };

      let currentGroups = [];
      let currentEvents = [];
      let mapboxMap = null;
      const activeMarkers = []; // mapboxgl.Marker instances, cleared on each renderMap

      function escapeHtml(value) {
        return String(value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function addDays(dateString, days) {
        const [year, month, day] = dateString.split('-').map(Number);
        const date = new Date(Date.UTC(year, month - 1, day));
        date.setUTCDate(date.getUTCDate() + days);
        return date.toISOString().slice(0, 10);
      }

      function formatDateLabel(dateString) {
        const [year, month, day] = dateString.split('-').map(Number);
        const date = new Date(Date.UTC(year, month - 1, day));
        return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', timeZone: 'UTC' });
      }

      function matchesOrgInput(value) {
        const normalized = value.trim().toLowerCase();
        return organizations.find((organization) => organization.name.toLowerCase() === normalized) || null;
      }

      function updateRangeLabels() {
        const startDate = addDays(payload.baseDate, state.fromOffset);
        const endDate = addDays(payload.baseDate, state.toOffset);
        if (startLabel) startLabel.textContent = formatDateLabel(startDate);
        if (endLabel) endLabel.textContent = formatDateLabel(endDate);

        if (rangeFill) {
          const startPct = (state.fromOffset / 30) * 100;
          const endPct = (state.toOffset / 30) * 100;
          rangeFill.setAttribute(
            'style',
            `left:${startPct}%; width:${Math.max(endPct - startPct, 3)}%;`
          );
        }
      }

      function filterEvents() {
        const startDate = addDays(payload.baseDate, state.fromOffset);
        const endDate = addDays(payload.baseDate, state.toOffset);

        return allEvents.filter((event) => {
          const eventEnd = event.endDate || event.startDate;
          if (!(event.startDate <= endDate && eventEnd >= startDate)) return false;

          if (state.selectedTag) {
            const matchesTag =
              event.primaryTagSlug === state.selectedTag || event.secondaryTagSlug === state.selectedTag;
            if (!matchesTag) return false;
          }

          if (state.selectedOrg) {
            if (event.organization?.id !== state.selectedOrg && event.organization?.slug !== state.selectedOrg) {
              return false;
            }
          }

          return true;
        });
      }

      function groupEvents(events) {
        const grouped = new Map();

        events.forEach((event) => {
          const existing = grouped.get(event.location.id);
          const summary = {
            id: event.id,
            title: event.title,
            date: event.displayDate,
            time: event.displayTime,
            tag: event.primaryTag || event.secondaryTag || 'Event',
            detailUrl: event.detailUrl,
            sortKey: `${event.startDate}T${event.startTime || '00:00:00'}`,
          };

          if (existing) {
            existing.eventCount += 1;
            existing.events.push(summary);
            return;
          }

          grouped.set(event.location.id, {
            id: event.location.id,
            name: event.location.name,
            address: event.location.address || 'Address unavailable',
            eventCount: 1,
            latitude: event.location.latitude,
            longitude: event.location.longitude,
            sortKey: summary.sortKey,
            events: [summary],
          });
        });

        return Array.from(grouped.values()).sort((a, b) => {
          if (a.sortKey && b.sortKey) {
            const sortOrder = a.sortKey.localeCompare(b.sortKey);
            if (sortOrder !== 0) return sortOrder;
          }
          return a.name.localeCompare(b.name);
        });
      }

      function updatePermalink() {
        const url = new URL(window.location.href);
        url.searchParams.set('from', String(state.fromOffset));
        url.searchParams.set('to', String(state.toOffset));

        if (state.selectedTag) url.searchParams.set('tag', state.selectedTag);
        else url.searchParams.delete('tag');

        if (state.selectedOrg) url.searchParams.set('org', state.selectedOrg);
        else url.searchParams.delete('org');

        if (state.selectedLocationId) url.searchParams.set('loc', state.selectedLocationId);
        else url.searchParams.delete('loc');

        history.replaceState({}, '', url);
        if (permalink) permalink.textContent = `${url.pathname}${url.search}`;
      }

      function renderList(groups) {
        if (!listContainer) return;

        if (groups.length === 0) {
          listContainer.innerHTML =
            '<div class="empty-state"><h3>No matching events</h3><p>Try widening the date range or clearing a filter.</p></div>';
          return;
        }

        listContainer.innerHTML = `
          <div class="grouped-event-list result-list">
            ${groups
              .map(
                (group) => `
                  <article
                    id="location-${escapeHtml(group.id)}"
                    class="location-group-card ${group.id === state.selectedLocationId ? 'is-selected' : ''}"
                    data-location-id="${escapeHtml(group.id)}"
                  >
                    <div class="location-group-head">
                      <div>
                        <div class="location-heading-row">
                          <span class="location-count-dot"></span>
                          <h3>${escapeHtml(group.name)}</h3>
                        </div>
                        <p class="location-meta">${escapeHtml(group.address)}</p>
                      </div>
                      <div class="location-count-badge">${group.eventCount} events</div>
                    </div>
                    <div class="event-stack">
                      ${group.events
                        .map(
                          (event) => `
                            <div class="mini-event-row">
                              <div>
                                <p class="mini-event-title"><a href="${escapeHtml(event.detailUrl)}">${escapeHtml(event.title)}</a></p>
                                <p class="mini-event-meta">${escapeHtml(event.date)} · ${escapeHtml(event.time)}</p>
                              </div>
                              <span class="mini-tag">${escapeHtml(event.tag)}</span>
                            </div>
                          `
                        )
                        .join('')}
                    </div>
                  </article>
                `
              )
              .join('')}
          </div>
        `;

        listContainer.querySelectorAll('.location-group-card').forEach((card) => {
          card.addEventListener('click', () => selectLocation(card.getAttribute('data-location-id')));
        });
      }

      function updateSummary(groups, events) {
        if (eventCount) eventCount.textContent = String(events.length);
        if (locationCount) locationCount.textContent = String(groups.length);
      }

      function updateCallout() {
        if (!callout) return;

        const selectedGroup = currentGroups.find((group) => group.id === state.selectedLocationId);
        if (!selectedGroup) {
          callout.innerHTML = `
            <p class="map-callout-eyebrow">No current matches</p>
            <h3>No venues match these filters</h3>
            <p>Adjust the date range, tags, or organization filter.</p>
          `;
          return;
        }

        callout.innerHTML = `
          <p class="map-callout-eyebrow">Selected location</p>
          <h3>${escapeHtml(selectedGroup.name)}</h3>
          <p>${selectedGroup.eventCount} events in the active window</p>
          <a href="#location-${escapeHtml(selectedGroup.id)}">Jump to grouped list</a>
        `;
      }

      function ensureSelection(groups) {
        if (groups.some((group) => group.id === state.selectedLocationId)) return;
        state.selectedLocationId = groups[0]?.id || '';
      }

      function fitMapToGroups(groups) {
        if (!mapboxMap) return;

        const targetGroups = groups.length > 0 ? groups : groupEvents(allEvents);
        if (targetGroups.length === 0) {
          mapboxMap.setCenter([-120.6615, 47.5963]);
          mapboxMap.setZoom(11);
          return;
        }

        if (targetGroups.length === 1) {
          mapboxMap.easeTo({ center: [targetGroups[0].longitude, targetGroups[0].latitude], zoom: 14 });
          return;
        }

        const bounds = new mapboxgl.LngLatBounds();
        targetGroups.forEach((group) => bounds.extend([group.longitude, group.latitude]));
        mapboxMap.fitBounds(bounds, { padding: 80, maxZoom: 15 });
      }

      function renderMap(groups, shouldFit = false) {
        if (!mapboxMap) return;

        // Remove existing markers
        activeMarkers.forEach((m) => m.remove());
        activeMarkers.length = 0;

        groups.forEach((group) => {
          const el = document.createElement('div');
          el.className = `event-map-marker ${group.id === state.selectedLocationId ? 'is-selected' : ''}`;
          el.setAttribute('role', 'button');
          el.setAttribute('aria-label', `${group.name} — ${group.eventCount} events`);
          el.innerHTML = `<span>${group.eventCount}</span>`;
          el.addEventListener('click', () => selectLocation(group.id, true));

          const marker = new mapboxgl.Marker({ element: el, anchor: 'center' })
            .setLngLat([group.longitude, group.latitude])
            .addTo(mapboxMap);

          activeMarkers.push(marker);
        });

        if (shouldFit) fitMapToGroups(groups);
      }

      function initMap() {
        if (!mapEl) return;

        const token = payload.mapboxToken;
        if (!token) {
          console.warn('PUBLIC_MAPBOX_TOKEN not set — map not initialized');
          return;
        }

        mapboxgl.accessToken = token;
        mapboxMap = new mapboxgl.Map({
          container: mapEl,
          style: 'https://basemaps.cartocdn.com/gl/positron-nolabels/style.json',
          center: [-120.6615, 47.5963],
          zoom: 11,
          attributionControl: true,
        });

        zoomInButton?.addEventListener('click', () => mapboxMap?.zoomIn());
        zoomOutButton?.addEventListener('click', () => mapboxMap?.zoomOut());
        fitButton?.addEventListener('click', () => fitMapToGroups(currentGroups));

        // Hide the placeholder backdrop once the map tiles load
        mapboxMap.once('load', () => renderMap(currentGroups, true));
      }

      function applyFilters() {
        currentEvents = filterEvents();
        currentGroups = groupEvents(currentEvents);
        ensureSelection(currentGroups);
        updateRangeLabels();
        updateSummary(currentGroups, currentEvents);
        renderList(currentGroups);
        updateCallout();
        updatePermalink();
        if (mapboxMap) renderMap(currentGroups, true);
      }

      function selectLocation(locationId, panToMarker = false) {
        if (!locationId) return;
        state.selectedLocationId = locationId;
        renderList(currentGroups);
        updateCallout();
        updatePermalink();

        if (mapboxMap) {
          renderMap(currentGroups, false);
          if (panToMarker) {
            const selectedGroup = currentGroups.find((group) => group.id === locationId);
            if (selectedGroup) {
              mapboxMap.easeTo({ center: [selectedGroup.longitude, selectedGroup.latitude] });
            }
          }
        }
      }

      startInput.addEventListener('input', () => {
        state.fromOffset = Number(startInput.value);
        if (state.toOffset <= state.fromOffset) {
          state.toOffset = state.fromOffset + 1;
          endInput.value = String(state.toOffset);
        }
        applyFilters();
      });

      endInput.addEventListener('input', () => {
        state.toOffset = Math.max(Number(endInput.value), state.fromOffset + 1);
        endInput.value = String(state.toOffset);
        applyFilters();
      });

      tagFilter?.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        const pill = target.closest('.tag-pill');
        if (!(pill instanceof HTMLButtonElement)) return;

        state.selectedTag = pill.dataset.tag || '';
        tagFilter.querySelectorAll('.tag-pill').forEach((button) => {
          button.classList.toggle('is-active', button === pill);
        });
        applyFilters();
      });

      orgInput.addEventListener('input', () => {
        const match = matchesOrgInput(orgInput.value);
        state.selectedOrg = match?.id || '';
        applyFilters();
      });

      orgClear?.addEventListener('click', () => {
        orgInput.value = '';
        state.selectedOrg = '';
        applyFilters();
      });

      resetButton?.addEventListener('click', () => {
        state.fromOffset = 0;
        state.toOffset = 10;
        state.selectedTag = '';
        state.selectedOrg = '';
        state.selectedLocationId = '';
        startInput.value = '0';
        endInput.value = '10';
        orgInput.value = '';
        tagFilter?.querySelectorAll('.tag-pill').forEach((button) => {
          button.classList.toggle('is-active', button.getAttribute('data-tag') === '');
        });
        applyFilters();
      });

      copyLinkButton?.addEventListener('click', async () => {
        const url = window.location.href;
        try {
          await navigator.clipboard.writeText(url);
          copyLinkButton.textContent = 'Copied';
          window.setTimeout(() => {
            copyLinkButton.textContent = 'Copy link';
          }, 1200);
        } catch {
          window.prompt('Copy this link', url);
        }
      });

      applyFilters();
      initMap();
      } catch (error) {
        console.error('[MAP] Error initializing map:', error);
        console.error('[MAP] Raw data element content:', dataElement?.textContent?.substring(0, 500));
        const container = document.getElementById('event-map-list');
        if (container) {
          container.innerHTML = '<div class="empty-state"><h3>Error loading map</h3><p>Check console for details.</p></div>';
        }
      }
    });
  </script>

  <style>
    .map-view-shell {
      background:
        radial-gradient(circle at top left, rgba(255, 230, 0, 0.12), transparent 28%),
        radial-gradient(circle at top right, rgba(33, 158, 188, 0.14), transparent 32%),
        linear-gradient(180deg, rgba(71, 64, 203, 0.06), rgba(255, 255, 255, 0.92) 24rem);
    }

    .map-view-card {
      background: rgba(255, 255, 255, 0.94);
      border: 1px solid rgba(229, 231, 235, 0.95);
      border-radius: 1.5rem;
      box-shadow: 0 18px 48px rgba(47, 68, 69, 0.08);
    }

    .map-stage,
    .result-panel {
      padding: 0.9rem;
    }

    .map-stage-head {
      display: flex;
      align-items: center;
      margin-bottom: 0.45rem;
    }

    .map-stage-kicker {
      display: flex;
      flex-wrap: wrap;
      gap: 0.45rem 0.75rem;
      align-items: center;
      margin: 0;
    }

    .map-stage-eyebrow,
    .panel-eyebrow,
    .map-callout-eyebrow {
      margin: 0;
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #6b7280;
    }

    .map-stage-title,
    .panel-header h2,
    .map-callout h3 {
      margin: 0;
      color: #111827;
      line-height: 1.05;
    }

    .map-stage-title {
      font-size: 0.95rem;
      font-weight: 600;
    }

    .map-canvas {
      position: relative;
      overflow: hidden;
      min-height: 42rem;
      border-radius: 1.35rem;
      border: 1px solid #dbe3ea;
      background: linear-gradient(145deg, #edf6f5 0%, #f7fafc 44%, #eef2ff 100%);
    }

    .map-empty-backdrop {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 18% 24%, rgba(255, 255, 255, 0.7), transparent 14rem),
        radial-gradient(circle at 72% 68%, rgba(33, 158, 188, 0.12), transparent 18rem),
