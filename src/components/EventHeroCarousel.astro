---
import EventCarouselCard from './EventCarouselCard.astro';
const { events = [], count = 12 } = Astro.props;

// Featured events happening within 7 days go first; the rest are sprinkled evenly throughout.
function sprinkleFeatured(events: any[]): any[] {
  const today = new Date();
  today.setHours(0, 0, 0, 0);
  const nextWeek = new Date(today);
  nextWeek.setDate(today.getDate() + 7);

  const featuredSoon  = events.filter((e: any) => e.featured && new Date(e.start_date) <= nextWeek);
  const rest          = events.filter((e: any) => !e.featured);
  const featuredLater = events.filter((e: any) => e.featured && new Date(e.start_date) >  nextWeek);

  if (featuredLater.length === 0) {
    return [...featuredSoon, ...rest].slice(0, count);
  }

  // Insert featuredLater events at evenly-spaced positions within rest
  const interval = Math.max(2, Math.ceil(rest.length / (featuredLater.length + 1)));
  const sprinkled: any[] = [];
  let fIdx = 0;
  for (let i = 0; i < rest.length; i++) {
    sprinkled.push(rest[i]);
    if ((i + 1) % interval === 0 && fIdx < featuredLater.length) {
      sprinkled.push(featuredLater[fIdx++]);
    }
  }
  while (fIdx < featuredLater.length) sprinkled.push(featuredLater[fIdx++]);

  return [...featuredSoon, ...sprinkled].slice(0, count);
}

const displayEvents = sprinkleFeatured(events as any[]);
const hasEvents = displayEvents.length > 0;
---

{hasEvents && (
  <div class="embla relative">
    <div class="embla__container">
      {displayEvents.map((event, index) => (
        <div class="embla__slide flex-shrink-0">
          <EventCarouselCard event={event} tags={{ primary: event.primary_tag?.name, secondary: event.secondary_tag?.name }} />
        </div>
      ))}
    </div>
    <button aria-label="Previous" id="embla-prev" class="hidden md:flex bg-white hover:bg-gray-50 rounded-full w-10 h-10 items-center justify-center absolute left-2 top-1/2 -translate-y-1/2 z-10 shadow-lg border border-gray-200">
      <span class="material-symbols-outlined text-2xl">chevron_left</span>
    </button>
    <button aria-label="Next" id="embla-next" class="hidden md:flex bg-white hover:bg-gray-50 rounded-full w-10 h-10 items-center justify-center absolute right-2 top-1/2 -translate-y-1/2 z-10 shadow-lg border border-gray-200">
      <span class="material-symbols-outlined text-2xl">chevron_right</span>
    </button>
    <script type="module" src="/embla-init.js"></script>
  </div>
)}

{!hasEvents && (
    <div class="flex items-center justify-center h-96 bg-gray-100 rounded-lg">
      <div class="text-center">
        <p class="text-gray-500 text-lg">No events to display</p>
        <a href="/submit" class="text-blue-600 hover:text-blue-800 font-medium mt-2 inline-block">
          Submit the first event →
        </a>
      </div>
    </div>
)}

<style is:global>
.embla {
  position: relative;
  width: 100%;
  margin: 0 auto;
  margin-top: 20px;
  padding: 0 0.5rem;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow-x: hidden;
}
.embla__container {
  display: flex;
  flex-wrap: nowrap;
  max-width: 100%;
  min-width: 0;
}
.embla__slide {
  flex: 0 0 280px;
  min-width: 280px;
  max-width: 280px;
  margin: 0 4px;
  cursor: grab;
}
@media (min-width: 400px) {
  .embla__slide {
    flex: 0 0 320px;
    min-width: 320px;
    max-width: 320px;
  }
}
</style>

<style>
.line-clamp-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.line-clamp-3 {
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
</style> 