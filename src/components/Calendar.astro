---
import { db } from '../lib/supabase';
import { transformEventForCalendar } from '../lib/event-utils';

export interface Props {
  title?: string;
  defaultView?: 'week' | 'day' | 'month';
  showSearch?: boolean;
  showCategoryFilter?: boolean;
  initialTag?: string;
  initialOrg?: string;
  /** Keep only events whose primary OR secondary tag matches (server-side). */
  filterTags?: string[];
  /** Pre-built calendar events to merge in (already in calendar shape). */
  extraEvents?: any[];
}

const {
  title = 'Calendar',
  defaultView = 'week',
  showSearch = true,
  showCategoryFilter = true,
  initialTag = '',
  initialOrg = '',
  filterTags,
  extraEvents = [],
} = Astro.props;

const { data: allEvents, error: eventsError } = await db.events.getAll();
if (eventsError) {
  console.error('Error fetching events:', eventsError);
}

let sourceEvents = allEvents || [];
if (filterTags && filterTags.length) {
  const wanted = new Set(filterTags.map((t) => t.toLowerCase()));
  sourceEvents = sourceEvents.filter((e: any) =>
    wanted.has((e.primary_tag?.name || '').toLowerCase()) ||
    wanted.has((e.secondary_tag?.name || '').toLowerCase())
  );
}

const calendarEvents = [
  ...sourceEvents.map(transformEventForCalendar).filter(Boolean),
  ...extraEvents,
];
---

{eventsError ? (
  <div class="py-12 text-center text-gray-500">
    <p>Unable to load events. Please try again later.</p>
  </div>
) : (
  <div
    id="calendar"
    data-events={JSON.stringify(calendarEvents)}
    data-title={title}
    data-default-view={defaultView}
    data-initial-tag={initialTag}
    data-initial-org={initialOrg}
    data-show-search={String(showSearch)}
    data-show-category-filter={String(showCategoryFilter)}
    style="display:flex;flex-direction:column;min-height:0"
  >
    <div id="cal-toolbar" class="cal-toolbar"></div>
    <div id="cal-subbar" class="cal-subbar"></div>
    <div id="cal-grid" class="cal-grid-container"></div>
  </div>
)}

<script src="/calendar.js" is:inline></script>
