{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../src/lib/config.ts",
    "../../src/types/database.ts",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
