# Mobile app environment variables
# Copy this file to .env.local and fill in values

# Backend API base URL
# Dev:  http://localhost:4321
# Prod: https://dertown.org (or your custom domain)
EXPO_PUBLIC_API_BASE_URL=http://localhost:4321

# Mapbox public token — for map tile rendering at runtime
# Get from: https://account.mapbox.com/access-tokens/
# Note: EAS builds also need MAPBOX_DOWNLOADS_TOKEN (secret sk. token) as a build secret
EXPO_PUBLIC_MAPBOX_TOKEN=pk.your_public_token_here
