{
  "name": "dertown",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build:validate": "npm run validate-theme-colors && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint src/ --ext .js,.ts,.astro",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "test": "tsx src/lib/__tests__/date-time-formatting.test.ts",
    "test:filtering": "tsx src/lib/__tests__/event-filtering.test.ts",
    "test:fullcalendar": "tsx src/lib/__tests__/fullcalendar-utc.test.ts",
    "test:timezone": "TZ=UTC tsx scripts/validate_timezone.mjs",
    "validate-theme-colors": "node --loader ts-node/esm scripts/validate_theme_colors.ts",
    "setup-env": "echo 'Create .env.local with: SUPABASE_URL=http://127.0.0.1:54321 and SUPABASE_ANON_KEY=your-key'",
    "test:email-ingest": "tsx src/lib/__tests__/email-ingest.test.ts",
    "test:activity-fields": "tsx src/lib/__tests__/activity-fields.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.103.0",
    "@astrojs/netlify": "^5.5.4",
    "@astrojs/solid-js": "^6.0.1",
    "@astrojs/tailwind": "^6.0.2",
    "@date-fns/tz": "^1.5.0",
    "@shoelace-style/shoelace": "^2.20.1",
    "@types/rrule": "^2.2.9",
    "astro": "^4.16.19",
    "cheerio": "^1.2.0",
    "date-fns": "^4.4.0",
    "embla-carousel": "^8.6.0",
    "js-yaml": "^4.2.0",
    "mapbox-gl": "^3.24.0",
    "marked": "^18.0.5",
    "node-ical": "^0.26.1",
    "resend": "^6.12.4",
    "rollup-plugin-copy": "^3.5.0",
    "rrule": "^2.8.1",
    "solid-js": "^1.9.13",
    "tablesort": "^5.7.1",
    "tailwindcss": "^3.4.17",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "@tailwindcss/typography": "^0.5.20",
    "@types/js-yaml": "^4.0.9",
    "@types/marked": "^5.0.2",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.34.1",
    "astro-eslint-parser": "^1.4.0",
    "autoprefixer": "^10.5.0",
    "dotenv": "^16.5.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-prettier": "^5.5.6",
    "markdownlint-cli": "^0.48.0",
    "postcss": "^8.5.6",
    "prettier": "^3.8.4",
    "prettier-plugin-astro": "^0.14.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4"
  }
}
